<node id="C6728">
<data key="n_label">Gardner Syndrome</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Associated Disease/Neoplasm</data>
<data key="n_research_axis">Associated conditions</data>
<data key="n_semantic_types">Disease or Syndrome</data>
<data key="n_umls_cui">C0017097</data>
<data key="n_definition">A variant of familial adenomatous polyposis. It is an autosomal dominant syndrome characterized by multiple colonic polyps predisposing to carcinoma of the colon, osteomas of the skull, epidermoid cysts, and fibromas. It is associated with mutation of the APC gene.</data>
<data key="n_aliases">Gardner Syndrome|Gardner's Syndrome</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C6728</data>
</node>
<node id="C33923">
<data key="n_label">Glandular Cell</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Cell</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Cell</data>
<data key="n_umls_cui">C1517548</data>
<data key="n_definition">An epithelial cell which may release secretions to a free epithelial surface (exocrine) or to the circulatory system (endocrine).</data>
<data key="n_aliases">Glandular Cell</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C33923</data>
</node>
