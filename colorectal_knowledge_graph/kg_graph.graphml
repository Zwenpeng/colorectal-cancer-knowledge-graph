<node id="C5543">
<data key="n_label">Cecum Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1332866</data>
<data key="n_definition">An adenocarcinoma arising from the cecum. It is more frequently seen in populations with a Western type diet and in patients with a history of chronic inflammatory bowel disease. Histologic variants include mucinous adenocarcinoma, signet ring cell carcinoma, medullary carcinoma, serrated adenocarcinoma, cribriform comedo-type adenocarcinoma, and micropapillary adenocarcinoma.</data>
<data key="n_aliases">Adenocarcinoma of Cecum|Adenocarcinoma of the Cecum|Cecal Adenocarcinoma|Cecum Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C5543</data>
</node>
<node id="C3491">
<data key="n_label">Cecum Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Disease Concept</data>
<data key="n_research_axis">Disease taxonomy</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C0149640</data>
<data key="n_definition">A malignant epithelial neoplasm that arises from the cecum and invades through the muscularis mucosa into the submucosa. The vast majority are adenocarcinomas.</data>
<data key="n_aliases">Carcinoma of Cecum|Carcinoma of the Cecum|Cecal Cancer|Cecal Carcinoma|Cecum Cancer|Cecum Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C3491</data>
</node>
<node id="C36309">
<data key="n_label">Colon Carcinoma Metastatic in the Liver</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Clinical Course</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1333085</data>
<data key="n_definition">A carcinoma that originates from the colonic wall and has spread to the liver.</data>
<data key="n_aliases">Colon Carcinoma Metastatic in the Liver|Colon Carcinoma Metastatic to the Liver</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C36309</data>
</node>
<node id="C89815">
<data key="n_label">Colon Carcinoma Metastatic in the Lung</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Clinical Course</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C2983137</data>
<data key="n_definition">A carcinoma that originates from the colonic wall and has spread to the lungs.</data>
<data key="n_aliases">Colon Carcinoma Metastatic in the Lung|Colon Carcinoma Metastatic to the Lung</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C89815</data>
</node>
<node id="C96489">
<data key="n_label">Colon Cribriform Comedo-Type Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C3272813</data>
<data key="n_definition">A rare, invasive colon adenocarcinoma characterized by the presence of malignant cribriform glands with central necrotic changes.</data>
<data key="n_aliases">Colon Cribriform Comedo-Type Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C96489</data>
</node>
<node id="C213480">
<data key="n_label">Colon Hepatoid Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A rare and aggressive extrahepatic carcinoma that morphologically and immunophenotypically resembles hepatocellular carcinoma and arises from the colon.</data>
<data key="n_aliases">Colon Hepatoid Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C213480</data>
</node>
<node id="C45429">
<data key="n_label">Colon Intramucosal Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1707434</data>
<data key="n_definition">An adenocarcinoma that arises from the colonic glandular epithelium and invades the lamina propria or muscularis mucosa but not the submucosa.</data>
<data key="n_aliases">Colon Intramucosal Adenocarcinoma|Colon Intramucosal Neoplasia</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C45429</data>
</node>
<node id="C170977">
<data key="n_label">Colon Large Cell Neuroendocrine Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">An aggressive high-grade carcinoma with neuroendocrine differentiation that arises from the colon and is composed of malignant large cells. The mitotic count is more than 20 per 2 mm2 and/or the Ki-67 index is more than 20%.</data>
<data key="n_aliases">Colon Large Cell Neuroendocrine Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C170977</data>
</node>
<node id="C60641">
<data key="n_label">Colon Medullary Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Disease Concept</data>
<data key="n_research_axis">Disease taxonomy</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1880119</data>
<data key="n_definition">A colon adenocarcinoma characterized by the presence of sheets of malignant epithelial cells with vesicular nuclei, prominent nucleoli, and abundant eosinophilic cytoplasm. It usually has a favorable prognosis.</data>
<data key="n_aliases">Colon Medullary Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C60641</data>
</node>
<node id="C96492">
<data key="n_label">Colon Micropapillary Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C3272816</data>
<data key="n_definition">A rare, invasive colon adenocarcinoma characterized by the presence of clusters of malignant glandular cells within stromal spaces.</data>
<data key="n_aliases">Colon Micropapillary Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C96492</data>
</node>
<node id="C9453">
<data key="n_label">Colon Moderately Differentiated Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1333859</data>
<data key="n_definition">A colon adenocarcinoma characterized by the presence of a malignant cellular infiltrate with 50-95% glandular formation.</data>
<data key="n_aliases">Colon Moderately Differentiated Adenocarcinoma|Grade 2 Colon Adenocarcinoma|Grade II Colon Adenocarcinoma|Moderately Differentiated Colon Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C9453</data>
</node>
<node id="C7966">
<data key="n_label">Colon Mucinous Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C0279639</data>
<data key="n_definition">An invasive adenocarcinoma of the colon characterized by the presence of pools of extracellular mucin. Malignant glandular epithelial cells are present in the mucin collections. Mucin constitutes more than 50% of the lesion.</data>
<data key="n_aliases">Colloid Adenocarcinoma of Colon|Colloid Adenocarcinoma of the Colon|Colloid Colon Adenocarcinoma|Colloidal Adenocarcinoma of Colon|Colloidal Adenocarcinoma of the Colon|Colloidal Colon Adenocarcinoma|Colon Colloid Adenocarcinoma|Colon Colloidal Adenocarcinoma|Colon Mucinous Adenocarcinoma|Colonic Colloid Adenocarcinoma|Colonic Colloidal Adenocarcinoma|Colonic Mucinous Adenocarcinoma|Mucinous Adenocarcinoma of Colon|Mucinous Adenocarcinoma of the Colon|Mucinous Colon Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C7966</data>
</node>
<node id="C9454">
<data key="n_label">Colon Poorly Differentiated Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1333855</data>
<data key="n_definition">A colon adenocarcinoma characterized by the presence of a malignant cellular infiltrate with less than 50% glandular formation.</data>
<data key="n_aliases">Colon Poorly Differentiated Adenocarcinoma|Grade 3 Colon Adenocarcinoma|Grade III Colon Adenocarcinoma|Poorly Differentiated Colon Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C9454</data>
</node>
<node id="C96486">
<data key="n_label">Colon Serrated Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C3272810</data>
<data key="n_definition">A rare, invasive colon adenocarcinoma characterized by the presence of a malignant infiltrate with serrated glandular architecture.</data>
<data key="n_aliases">Colon Serrated Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C96486</data>
</node>
<node id="C7967">
<data key="n_label">Colon Signet Ring Cell Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1707436</data>
<data key="n_definition">An invasive adenocarcinoma of the colon characterized by the presence of malignant glandular epithelial cells which contain prominent intracytoplasmic mucin (signet ring cells). The signet ring cells constitute more than 50% of the malignant cells.</data>
<data key="n_aliases">Colon Signet Ring Cell Adenocarcinoma|Colon Signet-Ring Cell Adenocarcinoma|Colonic Signet Ring Cell Adenocarcinoma|Signet Ring Cell Adenocarcinoma of Colon|Signet Ring Cell Adenocarcinoma of the Colon|Signet Ring Cell Colon Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C7967</data>
</node>
<node id="C6761">
<data key="n_label">Colon Small Cell Neuroendocrine Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1333099</data>
<data key="n_definition">An aggressive high-grade carcinoma with neuroendocrine differentiation that arises from the colon and is composed of malignant small cells. The mitotic count is more than 20 per 2 mm2 and/or the Ki-67 index is more than 20%.</data>
<data key="n_aliases">Colon Oat Cell Carcinoma|Colon Small Cell Carcinoma|Colon Small Cell Neuroendocrine Cancer|Colon Small Cell Neuroendocrine Carcinoma|Colonic Oat Cell Carcinoma|Colonic Small Cell Carcinoma|Oat Cell Carcinoma of Colon|Oat Cell Carcinoma of the Colon|Oat Cell Colon Carcinoma|Small Cell Carcinoma of Colon|Small Cell Carcinoma of the Colon|Small Cell Colon Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C6761</data>
</node>
<node id="C9452">
<data key="n_label">Colon Well Differentiated Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1333866</data>
<data key="n_definition">A colon adenocarcinoma characterized by the presence of a malignant cellular infiltrate with more than 95% glandular formation.</data>
<data key="n_aliases">Colon Well Differentiated Adenocarcinoma|Grade 1 Colon Adenocarcinoma|Grade I Colon Adenocarcinoma|Well Differentiated Colon Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C9452</data>
</node>
<node id="C157355">
<data key="n_label">Colorectal Adenocarcinoma Metastatic in the Liver</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Clinical Course</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">An adenocarcinoma that originates from the colorectal area and has spread to the liver.</data>
<data key="n_aliases">Colorectal Adenocarcinoma Metastatic in the Liver</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C157355</data>
</node>
<node id="C226754">
<data key="n_label">Colorectal Low Grade Tubuloglandular Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Stage/Grade</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">An uncommon, low-grade adenocarcinoma that arises from the colon or rectum and is characterized by the presence of extremely well differentiated malignant small or medium sized glands with round or tubular shape and absence of desmoplastic stroma formation. It typically occurs in patients with long-standing inflammatory bowel disease and approximately 10% of inflammatory bowel disease-associated colorectal carcinomas are low-grade tubuloglandular adenocarcinomas.</data>
<data key="n_aliases">Colorectal LGTGA|Colorectal Low Grade Tubuloglandular Adenocarcinoma|Colorectal Low-Grade Tubuloglandular Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C226754</data>
</node>
<node id="C43586">
<data key="n_label">Colorectal Signet Ring Cell Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1707440</data>
<data key="n_definition">An invasive colorectal adenocarcinoma characterized by the presence of malignant glandular epithelial cells with prominent intracytoplasmic mucin resulting in the displacement of the nuclei. The malignant glandular cells with intracytoplasmic mucin constitute more than 50% of the malignant cellular infiltrate.</data>
<data key="n_aliases">Colorectal Signet Ring Cell Adenocarcinoma|Colorectal Signet Ring Cell Carcinoma|Colorectal Signet-Ring Cell Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C43586</data>
</node>
