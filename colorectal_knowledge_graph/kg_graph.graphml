<data key="n_semantic_types">Finding</data>
<data key="n_umls_cui">C1711212</data>
<data key="n_definition">A microscopic finding indicating the presence of cells with glandular differentiation in a tumor sample.</data>
<data key="n_aliases">Glandular Differentiation</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C43573</data>
