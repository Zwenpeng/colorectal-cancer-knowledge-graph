<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1333858</data>
<data key="n_definition">A rectal adenocarcinoma characterized by the presence of a malignant cellular infiltrate with less than 50% glandular formation.</data>
<data key="n_aliases">Grade 3 Rectal Adenocarcinoma|Grade III Rectal Adenocarcinoma|Poorly Differentiated Rectal Adenocarcinoma|Rectal Poorly Differentiated Adenocarcinoma</data>
