<node id="C2955">
<data key="n_label">Colorectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Root Concept</data>
<data key="n_research_axis">Disease taxonomy</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C0009402</data>
<data key="n_definition">A malignant epithelial neoplasm that arises from the colon or rectum and invades through the muscularis mucosa into the submucosa. The vast majority are adenocarcinomas. | Cancer that develops in the colon (the longest part of the large intestine) and/or the rectum (the last several inches of the large intestine before the anus).</data>
<data key="n_aliases">Colorectal (Colon or Rectal) Cancer|Colorectal Cancer|colorectal cancer|Colorectal cancer, NOS|Colorectal Carcinoma|CRC</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C2955</data>
</node>
<node id="C118808">
<data key="n_label">Childhood Colorectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Disease Concept</data>
<data key="n_research_axis">Disease taxonomy</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C3899669</data>
<data key="n_definition">A colorectal carcinoma occurring during childhood. | A rare colorectal carcinoma that occurs during childhood.</data>
<data key="n_aliases">Childhood Colorectal Carcinoma|Colorectal (Colon or Rectal) Cancer</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C118808</data>
</node>
<node id="C4910">
<data key="n_label">Colon Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Disease Concept</data>
<data key="n_research_axis">Disease taxonomy</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C0699790</data>
<data key="n_definition">A malignant epithelial neoplasm that arises from the colon and invades through the muscularis mucosa into the submucosa. The vast majority are adenocarcinomas. | Cancer that forms in the tissues of the colon (the longest part of the large intestine). Most colon cancers are adenocarcinomas (cancers that begin in cells that make and release mucus and other fluids).</data>
<data key="n_aliases">Carcinoma of Colon|Carcinoma of the Colon|Colon Cancer|colon cancer|Colon Carcinoma|Colonic Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C4910</data>
</node>
<node id="C5105">
<data key="n_label">Colorectal Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1319315</data>
<data key="n_definition">The most common type of colorectal carcinoma. It is characterized by the presence of malignant glandular epithelial cells invading through the muscularis mucosa into the submucosa. Histologic variants include mucinous adenocarcinoma, signet ring cell carcinoma, medullary carcinoma, serrated adenocarcinoma, cribriform comedo-type adenocarcinoma, and micropapillary adenocarcinoma.</data>
<data key="n_aliases">Colorectal (Colon or Rectal) Adenocarcinoma|Colorectal Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C5105</data>
</node>
<node id="C43589">
<data key="n_label">Colorectal Adenosquamous Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1707437</data>
<data key="n_definition">An unusual colorectal carcinoma characterized by the presence of adenocarcinoma and squamous cell carcinoma components.</data>
<data key="n_aliases">Colorectal (Colon or Rectal) Adenosquamous Cancer|Colorectal Adenosquamous Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C43589</data>
</node>
<node id="C90506">
<data key="n_label">Colorectal Cancer by AJCC v6 Stage</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Stage/Grade</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C2983705</data>
<data key="n_definition">A term that refers to the staging of colorectal carcinoma according to the American Joint Committee on Cancer, 6th edition.</data>
<data key="n_aliases">Colorectal Cancer by AJCC v6 Stage|Colorectal Carcinoma by AJCC v6 Stage</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C90506</data>
</node>
<node id="C91223">
<data key="n_label">Colorectal Cancer by AJCC v7 Stage</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Stage/Grade</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C2984087</data>
<data key="n_definition">A term that refers to the staging of colorectal carcinoma according to the American Joint Committee on Cancer, 7th edition.</data>
<data key="n_aliases">Colorectal Cancer by AJCC v7 Stage|Colorectal Carcinoma by AJCC v7 Stage</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C91223</data>
</node>
<node id="C134180">
<data key="n_label">Colorectal Cancer by AJCC v8 Stage</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Stage/Grade</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A term that refers to the staging of colorectal cancer according to the American Joint Committee on Cancer, 8th edition. This staging system applies to adenocarcinomas, high-grade neuroendocrine carcinomas, and squamous cell carcinomas of the colon and rectum. Appendiceal carcinomas, anal carcinomas, and well-differentiated neuroendocrine tumors (carcinoids) are not covered by this staging system. (from AJCC 8th Ed.)</data>
<data key="n_aliases">Colorectal Cancer by AJCC v8 Stage|Colorectal Carcinoma by AJCC v8 Stage</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C134180</data>
</node>
<node id="C226293">
<data key="n_label">Colorectal Carcinoma In Situ</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">An intraepithelial carcinoma arising from the colon or rectum without evidence of invasion.</data>
<data key="n_aliases">Colorectal Carcinoma In Situ</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C226293</data>
</node>
<node id="C96158">
<data key="n_label">Colorectal Mixed Adenoneuroendocrine Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C3272609</data>
<data key="n_definition">A carcinoma that arises from the colon or rectum and is characterized by the presence of a malignant glandular epithelial component and a malignant neuroendocrine component. At least 30 percent of either component should be present for the diagnosis to be made.</data>
<data key="n_aliases">Colorectal (Colon or Rectal) Mixed Adenoneuroendocrine Cancer|Colorectal MANEC|Colorectal Mixed Adenoneuroendocrine Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C96158</data>
</node>
<node id="C96156">
<data key="n_label">Colorectal Neuroendocrine Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C3272607</data>
<data key="n_definition">An aggressive high-grade carcinoma with neuroendocrine differentiation that arises from the colon or rectum. It is composed of malignant small or large cells. The mitotic count is more than 20 per 2 mm2 and/or the Ki-67 index is more than 20%.</data>
<data key="n_aliases">Colorectal (Colon or Rectal) Neuroendocrine Cancer|Colorectal NEC|Colorectal Neuroendocrine Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C96156</data>
</node>
<node id="C96494">
<data key="n_label">Colorectal Sarcomatoid Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C3272818</data>
<data key="n_definition">A biphasic colorectal carcinoma with a spindle cell sarcomatoid component.</data>
<data key="n_aliases">Colorectal (Colon or Rectal) Sarcomatoid Cancer|Colorectal Carcinoma With Sarcomatoid Components|Colorectal Sarcomatoid Carcinoma|Colorectal Spindle Cell Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C96494</data>
</node>
<node id="C43588">
<data key="n_label">Colorectal Squamous Cell Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1707442</data>
<data key="n_definition">A very rare colorectal carcinoma characterized by the presence of a malignant squamous cell infiltrate.</data>
<data key="n_aliases">Colorectal (Colon or Rectal) Squamous Cell Cancer|Colorectal Squamous Cell Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C43588</data>
</node>
<node id="C43591">
<data key="n_label">Colorectal Undifferentiated Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1707443</data>
<data key="n_definition">A usually aggressive carcinoma that arises from the colon or rectum and is composed of malignant cells which do not display evidence of glandular, squamous, or transitional cell differentiation.</data>
<data key="n_aliases">Colorectal Undifferentiated Carcinoma|Undifferentiated Colorectal (Colon or Rectal) Cancer</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C43591</data>
</node>
<node id="C205290">
<data key="n_label">Early Stage Colorectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Stage/Grade</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A stage term referring to colorectal carcinoma that is limited to the colon/rectum or local lymph nodes, without metastasis to distant anatomic sites.</data>
<data key="n_aliases">Early Stage Colorectal Cancer|Early Stage Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C205290</data>
</node>
<node id="C162256">
<data key="n_label">Hypermutated Colorectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Molecular Disease Subtype</data>
<data key="n_research_axis">Molecular genetics</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A colorectal carcinoma characterized by a high mutational rate caused by DNA mismatch repair deficiency or POLE/POLD1 driver mutations.</data>
<data key="n_aliases">Hypermutated Colorectal Cancer|Hypermutated Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C162256</data>
</node>
<node id="C212894">
<data key="n_label">Localized Colorectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Clinical Course</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">Colorectal carcinoma that is confined to the site in which it initially manifested without evidence of spread to other anatomic sites.</data>
<data key="n_aliases">Localized Colorectal Cancer|Localized Colorectal Carcinoma|Non-Metastatic Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C212894</data>
</node>
<node id="C156096">
<data key="n_label">Metastatic Colorectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Clinical Course</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A carcinoma that arises from the colon or rectum and has metastasized to another anatomic site.</data>
<data key="n_aliases">Metastatic Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C156096</data>
</node>
<node id="C173324">
<data key="n_label">Microsatellite Stable Colorectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Molecular Disease Subtype</data>
<data key="n_research_axis">Molecular genetics</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A colorectal carcinoma characterized by the absence of microsatellite instability.</data>
<data key="n_aliases">Microsatellite Stable Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C173324</data>
</node>
<node id="C218464">
<data key="n_label">Mismatch Repair Proficient Colorectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Molecular Disease Subtype</data>
<data key="n_research_axis">Molecular genetics</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A colorectal carcinoma in which the mismatch repair system is functional.</data>
<data key="n_aliases">Mismatch Repair Proficient Colorectal Carcinoma|MMRp Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C218464</data>
</node>
<node id="C9382">
<data key="n_label">Rectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Disease Concept</data>
<data key="n_research_axis">Disease taxonomy</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C0007113</data>
<data key="n_definition">A malignant epithelial neoplasm that arises from the rectum. The vast majority are adenocarcinomas. | Cancer that forms in the tissues of the rectum (the last several inches of the large intestine closest to the anus).</data>
<data key="n_aliases">Cancer of Rectum|Cancer of the Rectum|Carcinoma of Rectum|Carcinoma of the Rectum|Rectal Cancer|rectal cancer|Rectal Carcinoma|Rectum Cancer</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C9382</data>
</node>
<node id="C7421">
<data key="n_label">Rectosigmoid Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Disease Concept</data>
<data key="n_research_axis">Disease taxonomy</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1327709</data>
<data key="n_definition">A malignant epithelial neoplasm that arises from the rectosigmoid junction. The vast majority are adenocarcinomas.</data>
<data key="n_aliases">Rectosigmoid Cancer|Rectosigmoid Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C7421</data>
</node>
<node id="C8625">
<data key="n_label">Recurrent Colorectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
