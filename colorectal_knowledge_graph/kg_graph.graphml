<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Finding/Clinical Attribute</data>
<data key="n_research_axis">Phenotype/finding</data>
<data key="n_semantic_types">Finding</data>
<data key="n_umls_cui">C2987394</data>
<data key="n_definition">A morphologic finding indicating the presence of a malignant cellular infiltrate characterized by the presence of individual cells and/or tiny cellular aggregates.</data>
<data key="n_aliases">Poorly Cohesive Malignant Cellular Infiltrate</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C95744</data>
</node>
