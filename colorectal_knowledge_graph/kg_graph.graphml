<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">The reemergence of colorectal carcinoma after a period of remission, at or adjacent to the site of the original tumor.</data>
<data key="n_aliases">Locally Recurrent Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C190199</data>
</node>
