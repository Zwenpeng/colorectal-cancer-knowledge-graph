<data key="n_definition">A colon carcinoma characterized by the absence of microsatellite instability.</data>
<data key="n_aliases">Microsatellite Stable Colon Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C177777</data>
