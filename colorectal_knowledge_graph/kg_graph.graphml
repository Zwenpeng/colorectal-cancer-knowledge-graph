<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1868071</data>
<data key="n_definition">A polypoid adenoma that arises from, and protrudes into the lumen of, the colon.</data>
<data key="n_aliases">Adenomatous Polyp of Colon|Adenomatous Polyp of the Colon|Colon Adenomatous Polyp|Colonic Adenomatous Polyp</data>
