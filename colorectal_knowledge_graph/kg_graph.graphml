<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Terminology/Data Model</data>
<data key="n_research_axis">Terminology/data model</data>
<data key="n_semantic_types">Intellectual Product</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A two digit numerical identifier assigned to a specific tumor sample from a by the The Cancer Genome Atlas (TCGA) Biospecimen Core Resource (BCR).</data>
<data key="n_aliases">TCGA BCR Tumor Code Identifier|tumor code id|tumor_code_id</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C177584</data>
