<node id="C185165">
<data key="n_label">Oligometastatic Colorectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Clinical Course</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A colorectal carcinoma that has metastasized to a limited number of sites.</data>
<data key="n_aliases">Oligometastatic Colorectal Cancer|Oligometastatic Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C185165</data>
</node>
<node id="C202633">
<data key="n_label">Proximal Colon Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Disease Concept</data>
<data key="n_research_axis">Disease taxonomy</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A colon carcinoma that arises from cecum, ascending colon, or hepatic flexure.</data>
<data key="n_aliases">Proximal Colon Cancer|Proximal Colon Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C202633</data>
</node>
<node id="C9383">
<data key="n_label">Rectal Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C0149978</data>
<data key="n_definition">An adenocarcinoma arising from the rectum. It is more frequently seen in populations with a Western type diet and in patients with a history of chronic inflammatory bowel disease. Signs and symptoms include intestinal bleeding, anemia, and change in bowel habits. According to the degree of cellular differentiation, rectal adenocarcinomas are divided into well, moderately, and poorly differentiated. Histologic variants include mucinous adenocarcinoma, signet ring cell carcinoma, medullary carcinoma, serrated adenocarcinoma, cribriform comedo-type adenocarcinoma, and micropapillary adenocarcinoma.</data>
<data key="n_aliases">Adenocarcinoma - rectum|Adenocarcinoma of Rectum|Adenocarcinoma of the rectum|Adenocarcinoma of the Rectum|Rectal Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C9383</data>
</node>
<node id="C43594">
<data key="n_label">Rectal Adenosquamous Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1709865</data>
<data key="n_definition">An unusual rectal carcinoma characterized by the presence of glandular and squamous carcinomatous components. The two carcinomatous components may be admixed within the tumor, or the two may appear separately in different areas.</data>
<data key="n_aliases">Rectal Adenosquamous Cancer|Rectal Adenosquamous Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C43594</data>
</node>
<node id="C90508">
<data key="n_label">Rectal Cancer by AJCC v6 Stage</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Stage/Grade</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C2983707</data>
<data key="n_definition">A term that refers to the staging of rectal carcinoma according to the American Joint Committee on Cancer, 6th edition.</data>
<data key="n_aliases">Rectal Cancer by AJCC v6 Stage|Rectal Carcinoma by AJCC v6 Stage</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C90508</data>
</node>
<node id="C91225">
<data key="n_label">Rectal Cancer by AJCC v7 Stage</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Stage/Grade</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C2984089</data>
<data key="n_definition">A term that refers to the staging of rectal carcinoma according to the American Joint Committee on Cancer, 7th edition.</data>
<data key="n_aliases">Rectal Cancer by AJCC v7 Stage|Rectal Carcinoma by AJCC v7 Stage</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C91225</data>
</node>
<node id="C134258">
<data key="n_label">Rectal Cancer by AJCC v8 Stage</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Stage/Grade</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A term that refers to the staging of rectal cancer according to the American Joint Committee on Cancer, 8th edition. This staging system applies to adenocarcinomas, high-grade neuroendocrine carcinomas, and squamous cell carcinomas of the rectum. (from AJCC 8th Ed.)</data>
<data key="n_aliases">Rectal Cancer by AJCC v8 Stage|Rectal Carcinoma by AJCC v8 Stage</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C134258</data>
</node>
<node id="C226295">
<data key="n_label">Rectal Carcinoma In Situ</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">An intraepithelial carcinoma arising from the rectum without evidence of invasion.</data>
<data key="n_aliases">Carcinoma in situ of rectum|Rectal Carcinoma In Situ</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C226295</data>
</node>
<node id="C203385">
<data key="n_label">Rectal Neuroendocrine Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">An aggressive high-grade carcinoma with neuroendocrine differentiation that arises from the rectum. It is composed of malignant small or large cells. The mitotic count is more than 20 per 2 mm2 and/or the Ki-67 index is more than 20%.</data>
<data key="n_aliases">Rectal NEC|Rectal Neuroendocrine Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C203385</data>
</node>
<node id="C5556">
<data key="n_label">Rectal Sarcomatoid Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1335689</data>
<data key="n_definition">A biphasic rectal carcinoma with a spindle cell sarcomatoid component.</data>
<data key="n_aliases">Rectal Sarcomatoid Cancer|Rectal Sarcomatoid Carcinoma|Rectal Spindle Cell Carcinoma|Sarcomatoid Carcinoma of Rectum|Sarcomatoid Carcinoma of the Rectum</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C5556</data>
</node>
<node id="C5554">
<data key="n_label">Rectal Squamous Cell Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1335690</data>
<data key="n_definition">A very rare rectal carcinoma characterized by the presence of a malignant squamous cell infiltrate.</data>
<data key="n_aliases">Rectal Squamous Carcinoma|Rectal Squamous Cell Cancer|Rectal Squamous Cell Carcinoma|Squamous Carcinoma of Rectum|Squamous Carcinoma of the Rectum|Squamous Cell Carcinoma of Rectum|Squamous Cell Carcinoma of the Rectum</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C5554</data>
</node>
<node id="C7974">
<data key="n_label">Rectal Undifferentiated Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C0279657</data>
<data key="n_definition">A usually aggressive carcinoma that arises from the rectum and is composed of malignant cells which do not display evidence of glandular, squamous, or transitional cell differentiation.</data>
<data key="n_aliases">Anaplastic Carcinoma of Rectum|Anaplastic Carcinoma of the Rectum|Carcinoma Simplex of the Rectum.|Rectal Anaplastic Carcinoma|Rectal Undifferentiated Carcinoma|Undifferentiated Carcinoma of Rectum|Undifferentiated Carcinoma of the Rectum|Undifferentiated Rectal Cancer|Undifferentiated Rectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C7974</data>
</node>
<node id="C43584">
<data key="n_label">Rectosigmoid Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1711390</data>
<data key="n_definition">An adenocarcinoma arising from the rectosigmoid junction. It is more frequently seen in populations with a Western type diet and in patients with a history of chronic inflammatory bowel disease. Signs and symptoms include intestinal bleeding, anemia, and change in bowel habits. According to the degree of cellular differentiation, rectosigmoid adenocarcinomas are divided into well, moderately, and poorly differentiated. Histologic variants include mucinous adenocarcinoma, signet ring cell carcinoma, medullary carcinoma, serrated adenocarcinoma, cribriform comedo-type adenocarcinoma, and micropapillary adenocarcinoma.</data>
<data key="n_aliases">Rectosigmoid Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C43584</data>
</node>
<node id="C90509">
<data key="n_label">Rectosigmoid Cancer by AJCC v6 Stage</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Stage/Grade</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C2983708</data>
<data key="n_definition">A term that refers to the staging of rectosigmoid carcinoma according to the American Joint Committee on Cancer, 6th edition.</data>
<data key="n_aliases">Rectosigmoid Cancer by AJCC v6 Stage|Rectosigmoid Carcinoma by AJCC v6 Stage</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C90509</data>
</node>
<node id="C91226">
<data key="n_label">Rectosigmoid Cancer by AJCC v7 Stage</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Stage/Grade</data>
<data key="n_research_axis">Clinical stage/course</data>
