<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A colorectal carcinoma that has spread from its original site of growth to nearby tissues or lymph nodes.</data>
<data key="n_aliases">Locally Advanced Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C162766</data>
