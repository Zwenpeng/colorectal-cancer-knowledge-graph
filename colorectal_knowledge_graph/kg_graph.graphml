<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C0854750</data>
<data key="n_definition">The reemergence of colorectal carcinoma after a period of remission.</data>
<data key="n_aliases">Colorectal Cancer, Recurrent|Colorectal Carcinoma Recurrent|Recurrent Colorectal (Colon or Rectal) Cancer|Recurrent Colorectal Cancer|Recurrent Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C8625</data>
</node>
<node id="C147982">
<data key="n_label">Refractory Colorectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Clinical Course</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">Colorectal carcinoma that does not respond to treatment.</data>
<data key="n_aliases">Refractory Colorectal Cancer|Refractory Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C147982</data>
</node>
<node id="C162257">
<data key="n_label">Resectable Colorectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Clinical Course</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">Colorectal carcinoma that is amenable to surgical resection.</data>
<data key="n_aliases">Resectable Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C162257</data>
</node>
