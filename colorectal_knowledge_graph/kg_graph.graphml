<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1333865</data>
<data key="n_definition">A rectal adenocarcinoma characterized by the presence of a malignant cellular infiltrate with 50-95% glandular formation.</data>
<data key="n_aliases">Grade 2 Rectal Adenocarcinoma|Grade II Rectal Adenocarcinoma|Moderately Differentiated Rectal Adenocarcinoma|Rectal Moderately Differentiated Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C9450</data>
</node>
<node id="C7973">
<data key="n_label">Rectal Mucinous Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C0279652</data>
<data key="n_definition">An invasive adenocarcinoma of the rectum characterized by the presence of pools of extracellular mucin. Malignant glandular epithelial cells are present in the mucin collections. Mucin constitutes more than 50% of the lesion.</data>
<data key="n_aliases">Colloid Adenocarcinoma of Rectum|Colloid Adenocarcinoma of the Rectum|Colloidal Adenocarcinoma of Rectum|Colloidal Adenocarcinoma of the Rectum|Mucinous Adenocarcinoma of Rectum|Mucinous Adenocarcinoma of the Rectum|Rectal Colloid Adenocarcinoma|Rectal Colloidal Adenocarcinoma|Rectal Mucinous Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C7973</data>
</node>
<node id="C9449">
