<data key="n_umls_cui">C1836306</data>
<data key="n_definition">This gene is involved in the regulation of gene expression and plays a tumor suppressor role in lung, colorectal and breast carcinomas, leukemia, medulloblastoma and glioblastoma multiforme.</data>
