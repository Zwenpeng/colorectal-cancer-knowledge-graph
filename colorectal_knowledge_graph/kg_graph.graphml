<node id="C3764">
<data key="n_label">Adenomatous Polyp</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Associated Disease/Neoplasm</data>
<data key="n_research_axis">Associated conditions</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C0206677</data>
<data key="n_definition">A polypoid neoplasm that arises from the glandular epithelium of the gastrointestinal tract. There is a proliferation of glandular cells that may display dysplastic cytologic features. Representative examples include the adenomatous polyps of the colon and rectum.</data>
<data key="n_aliases">Adenomatous Polyp|Adenomatous polyp, NOS|Gastrointestinal Tract Adenomatous Polyp|GI Tract Adenomatous Polyp|Polypoid adenoma|Polypoid Adenoma</data>
