<data key="n_aliases">Advanced Microsatellite Stable Colorectal Cancer|Advanced Microsatellite Stable Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C142868</data>
</node>
