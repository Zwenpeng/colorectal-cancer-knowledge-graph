<node id="C155746">
<data key="n_label">Modified FOLFOX6 Regimen</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Treatment Regimen</data>
<data key="n_research_axis">Therapy</data>
<data key="n_semantic_types">Therapeutic or Preventive Procedure</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A regimen consisting of leucovorin, infusional fluorouracil and oxaliplatin used for the treatment of anal carcinoma, esophageal and esophagogastric junction, gastric, occult primary, colorectal cancers, and appendiceal, small bowel, non-urothelial and urothelial bladder cancer, well-differentiated grade 3 neuroendocrine tumors (NETs), NETs of the pancreas, and extrapulmonary poorly differentiated neuroendocrine carcinoma/large or small cell carcinoma/mixed neuroendocrine-non-neuroendocrine neoplasm. This modified version differs from the FOLFOX6 regimen in that the dose of oxaliplatin is lower.</data>
<data key="n_aliases">mFOLFOX-6|mFOLFOX-6 Regimen|mFOLFOX6|mFOLFOX6 (L-Leucovorin)|Modified FOLFOX-6|Modified FOLFOX6|Modified FOLFOX6 Regimen|Modified Folinic Acid-Fluorouracil-Oxaliplatin-6 Regimen</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C155746</data>
</node>
