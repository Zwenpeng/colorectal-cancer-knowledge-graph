<node id="C12378">
<data key="n_label">Digestive System</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Anatomic Site</data>
<data key="n_research_axis">Anatomy</data>
<data key="n_semantic_types">Body System</data>
<data key="n_umls_cui">C0012240</data>
<data key="n_definition">The organs that take in food and turn it into products that the body can use to stay healthy. Waste products the body cannot use leave the body through bowel movements. The digestive system includes the salivary glands, mouth, esophagus, stomach, liver, pancreas, gallbladder, small and large intestines, and rectum. | The system that includes the esophagus, stomach, small and large intestine, anus, liver, biliary tract, and pancreas. | The system that includes the esophagus, stomach, small and large intestine, anus, liver, biliary tract, and pancreas. (NCI)</data>
<data key="n_aliases">Body System, Gastrointestinal|Digestive System|digestive system|Gastrointestinal|Gastrointestinal Body System|Gastrointestinal Organ System|Gastrointestinal System|GASTROINTESTINAL SYSTEM|Organ System, Gastrointestinal</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C12378</data>
</node>
<node id="C210140">
<data key="n_label">Digestive System Adenocarcinoma</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Associated Disease/Neoplasm</data>
<data key="n_research_axis">Associated conditions</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">An adenocarcinoma that arises from any part of the digestive system.</data>
<data key="n_aliases">Digestive System Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C210140</data>
</node>
<node id="C226527">
<data key="n_label">Digestive System Adenosquamous Carcinoma</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Associated Disease/Neoplasm</data>
<data key="n_research_axis">Associated conditions</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A rare carcinoma that arises from the digestive system and is characterized by the presence of adenocarcinoma and squamous cell carcinoma components.</data>
<data key="n_aliases">Digestive System Adenosquamous Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C226527</data>
</node>
<node id="C96963">
<data key="n_label">Digestive System Carcinoma</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Associated Disease/Neoplasm</data>
<data key="n_research_axis">Associated conditions</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C0151544</data>
<data key="n_definition">A malignant neoplasm that arises from the epithelium of any part of the digestive system. Representative examples include colorectal carcinoma, esophageal carcinoma, and pancreatic carcinoma.</data>
<data key="n_aliases">Carcinoma of the Gastrointestinal System|Digestive System Carcinoma|Gastrointestinal System Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C96963</data>
</node>
<node id="C35180">
<data key="n_label">Digestive System Carcinoma In Situ</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Associated Disease/Neoplasm</data>
<data key="n_research_axis">Associated conditions</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C0154057</data>
<data key="n_definition">An intraepithelial carcinoma arising from any part of the digestive system without evidence of invasion.</data>
<data key="n_aliases">Carcinoma in situ of digestive organ, unspecified|Digestive System Carcinoma In Situ|Gastrointestinal System Carcinoma In Situ</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C35180</data>
</node>
<node id="C154617">
<data key="n_label">Digestive System Large Cell Neuroendocrine Carcinoma</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Associated Disease/Neoplasm</data>
<data key="n_research_axis">Associated conditions</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">An aggressive high-grade carcinoma with neuroendocrine differentiation that arises from the digestive system and is composed of malignant large cells. The mitotic count is more than 20 per 2 mm2 and/or the Ki-67 index is more than 20% (often more than 70%).</data>
<data key="n_aliases">Digestive System Large Cell Neuroendocrine Carcinoma|Gastrointestinal System Large Cell Neuroendocrine Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C154617</data>
</node>
<node id="C95406">
<data key="n_label">Digestive System Mixed Adenoneuroendocrine Carcinoma</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Associated Disease/Neoplasm</data>
<data key="n_research_axis">Associated conditions</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C2987129</data>
<data key="n_definition">A carcinoma that arises from the digestive system and is characterized by the presence of a malignant glandular epithelial component and a malignant neuroendocrine component. At least 30% of either component should be present for the diagnosis to be made.</data>
<data key="n_aliases">Digestive System Mixed Adenoneuroendocrine Cancer|Digestive System Mixed Adenoneuroendocrine Carcinoma|Gastrointestinal MANEC|Gastrointestinal Mixed Adenoneuroendocrine Carcinoma|MANEC|Mixed adenoneuroendocrine carcinoma|Mixed Adenoneuroendocrine Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C95406</data>
</node>
<node id="C154641">
<data key="n_label">Digestive System Small Cell Neuroendocrine Carcinoma</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Associated Disease/Neoplasm</data>
<data key="n_research_axis">Associated conditions</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">An aggressive high-grade carcinoma with neuroendocrine differentiation that arises from the digestive system and is composed of malignant small cells. The mitotic count is more than 20 per 2 mm2 and/or the Ki-67 index is more than 20% (often more than 70%).</data>
<data key="n_aliases">Digestive System Small Cell Carcinoma|Digestive System Small Cell Neuroendocrine Carcinoma|Gastrointestinal System Small Cell Neuroendocrine Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C154641</data>
</node>
<node id="C226528">
<data key="n_label">Digestive System Undifferentiated Carcinoma</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Associated Disease/Neoplasm</data>
<data key="n_research_axis">Associated conditions</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A usually aggressive carcinoma that arises from the digestive system and is composed of malignant cells which do not display evidence of glandular, squamous, or transitional cell differentiation.</data>
<data key="n_aliases">Digestive System Undifferentiated Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C226528</data>
</node>
