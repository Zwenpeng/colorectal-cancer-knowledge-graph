<data key="n_semantic_types">Body Space or Junction</data>
<data key="n_umls_cui">C0230139</data>
<data key="n_definition">The cavity enclosed by the ribs between the diaphragm and the neck. | The cavity in the vertebrate body enclosed by the ribs between the diaphragm and the neck and containing the lungs and heart.</data>
<data key="n_aliases">BODY CAVITY, THORACIC|Thoracic Cavity|THORACIC CAVITY</data>
