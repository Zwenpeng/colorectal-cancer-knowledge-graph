<node id="C96490">
<data key="n_label">Rectal Cribriform Comedo-Type Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C3272814</data>
<data key="n_definition">A rare, invasive rectal adenocarcinoma characterized by the presence of malignant cribriform glands with central necrotic changes.</data>
<data key="n_aliases">Rectal Cribriform Comedo-Type Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C96490</data>
</node>
<node id="C213481">
<data key="n_label">Rectal Hepatoid Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A rare and aggressive extrahepatic carcinoma that morphologically and immunophenotypically resembles hepatocellular carcinoma and arises from the rectum.</data>
<data key="n_aliases">Rectal Hepatoid Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C213481</data>
</node>
<node id="C176697">
<data key="n_label">Rectal Large Cell Neuroendocrine Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">An aggressive high-grade carcinoma with neuroendocrine differentiation that arises from the rectum and is composed of malignant large cells. The mitotic count is more than 20 per 2 mm2 and/or the Ki-67 index is more than 20%.</data>
<data key="n_aliases">Rectal Large Cell Neuroendocrine Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C176697</data>
</node>
<node id="C60640">
<data key="n_label">Rectal Medullary Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Disease Concept</data>
<data key="n_research_axis">Disease taxonomy</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1882915</data>
<data key="n_definition">A rectal adenocarcinoma characterized by the presence of sheets of malignant epithelial cells with vesicular nuclei, prominent nucleoli, and abundant eosinophilic cytoplasm. It usually has a favorable prognosis.</data>
<data key="n_aliases">Rectal Medullary Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C60640</data>
</node>
