<node id="C96487">
<data key="n_label">Rectal Serrated Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C3272811</data>
<data key="n_definition">A rare, invasive rectal adenocarcinoma characterized by the presence of a malignant infiltrate with serrated glandular architecture.</data>
<data key="n_aliases">Rectal Serrated Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C96487</data>
