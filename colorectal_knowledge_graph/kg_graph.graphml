<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Finding/Clinical Attribute</data>
<data key="n_research_axis">Phenotype/finding</data>
<data key="n_semantic_types">Finding</data>
<data key="n_umls_cui">C0002793</data>
<data key="n_definition">A morphologic finding indicating the presence of a malignant cellular infiltrate characterized by the presence of large pleomorphic cells, necrosis, and high mitotic activity in a tissue sample.</data>
<data key="n_aliases">Anaplasia|Anaplastic Change|Anaplastic Lesion</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C36113</data>
</node>
