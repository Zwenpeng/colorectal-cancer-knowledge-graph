<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Gene/Genome</data>
<data key="n_research_axis">Molecular genetics</data>
<data key="n_semantic_types">Gene or Genome</data>
<data key="n_umls_cui">C0162832</data>
<data key="n_definition">This gene plays a role in signal transduction. It is involved in both adhesion and migration of cells.</data>
<data key="n_aliases">APC|APC Gene|APC Regulator of WNT Signaling Pathway Gene</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C17567</data>
