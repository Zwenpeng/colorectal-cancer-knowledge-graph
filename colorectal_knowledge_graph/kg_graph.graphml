<data key="n_research_axis">Molecular genetics</data>
<data key="n_semantic_types">Gene or Genome</data>
<data key="n_umls_cui">C0079414</data>
<data key="n_definition">This gene plays a role in the regulation of several processes that determine neuronal cell morphology.</data>
<data key="n_aliases">DCC|DCC Gene|Deleted in Colorectal Carcinoma Gene</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C17358</data>
