<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A microsatellite stable carcinoma that arises from the colon or rectum and has metastasized to other anatomic sites.</data>
<data key="n_aliases">Metastatic Microsatellite Stable Colorectal Cancer|Metastatic Microsatellite Stable Colorectal Carcinoma</data>
