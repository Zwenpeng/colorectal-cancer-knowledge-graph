<node id="C52458">
<data key="n_label">APC wt Allele</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Gene/Genome</data>
<data key="n_research_axis">Molecular genetics</data>
<data key="n_semantic_types">Gene or Genome</data>
<data key="n_umls_cui">C1705766</data>
<data key="n_definition">Human APC wild-type allele is located within 5q21-q22 and is approximately 108 kb in length. This allele, which encodes adenomatosis polyposis coli protein, is involved in the progression of Wnt protein mediated signaling. Mutations in this gene are associated with familial adenomatous polyposis, an autosomal dominant pre-malignant disease that usually progresses to malignancy.</data>
<data key="n_aliases">Adenomatosis Polyposis Coli Gene|APC Regulator of WNT Signaling Pathway wt Allele|APC wt Allele|APC, WNT Signaling Pathway Regulator Gene|BTPS2|DP2|DP2.5|DP3|FAP|FPC|GS|PPP1R46|Protein Phosphatase 1, Regulatory Subunit 46 Gene</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C52458</data>
</node>
