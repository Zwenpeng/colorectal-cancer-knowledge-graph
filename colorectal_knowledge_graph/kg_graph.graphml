<node id="C63594">
<data key="n_label">IFL Regimen</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Treatment Regimen</data>
<data key="n_research_axis">Therapy</data>
<data key="n_semantic_types">Therapeutic or Preventive Procedure</data>
<data key="n_umls_cui">C1881119</data>
<data key="n_definition">A regimen consisting of irinotecan, fluorouracil and leucovorin, all administered as bolus doses, and used for the treatment of advanced stage colorectal cancer.</data>
<data key="n_aliases">IFL|IFL Regimen|IFL-Modified Saltz Regimen|IFL-Saltz Regimen|Irinotecan-Fluorouracil-Leucovorin Regimen|Irinotecan/Fluorouracil/Leucovorin</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C63594</data>
