<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Treatment Regimen</data>
<data key="n_research_axis">Therapy</data>
<data key="n_semantic_types">Therapeutic or Preventive Procedure</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A modified version of the FOLFOX regimen consisting of leucovorin, infusional fluorouracil and oxaliplatin that may be used in the treatment of colorectal cancer.</data>
<data key="n_aliases">mFOLFOX|mFOLFOX Regimen|Modified FOLFOX|Modified FOLFOX Regimen|Modified Folinic Acid-Fluorouracil-Oxaliplatin Regimen</data>
