<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Gene/Genome</data>
<data key="n_research_axis">Molecular genetics</data>
<data key="n_semantic_types">Amino Acid, Peptide, or Protein|Enzyme</data>
<data key="n_umls_cui">C1869547</data>
<data key="n_definition">Tyrosine-protein phosphatase non-receptor type 12 (780 aa, ~88 kDa) is encoded by the human PTPN12 gene. This protein plays a role in both cytoskeleton morphology and protein dephosphorylation.</data>
<data key="n_aliases">EC 3.1.3.48|Protein Tyrosine Phosphatase G1|Protein Tyrosine Phosphatase, Non-Receptor Type 12|PTP-PEST|PTPG1|PTPN12|Tyrosine-Protein Phosphatase Non-Receptor Type 12</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C26341</data>
</node>
