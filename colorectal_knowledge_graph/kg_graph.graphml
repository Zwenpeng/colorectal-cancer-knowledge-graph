<data key="n_label">Unresectable Colorectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Clinical Course</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A colorectal carcinoma that is not amenable to surgical resection.</data>
<data key="n_aliases">Unresectable Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C162600</data>
</node>
<node id="C162475">
<data key="n_label">Advanced Colorectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Clinical Course</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">Colorectal carcinoma that has spread extensively to other anatomic sites or is no longer responding to treatment.</data>
<data key="n_aliases">Advanced Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C162475</data>
</node>
<node id="C118823">
<data key="n_label">Childhood Rectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Disease Concept</data>
<data key="n_research_axis">Disease taxonomy</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C3899643</data>
<data key="n_definition">A rare carcinoma of the rectum that occurs during childhood.</data>
<data key="n_aliases">Childhood Rectal Carcinoma|Rectal Cancer</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C118823</data>
</node>
<node id="C4349">
<data key="n_label">Colon Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C0338106</data>
<data key="n_definition">An adenocarcinoma arising from the colon. It is more frequently seen in populations with a Western type diet and in patients with a history of chronic inflammatory bowel disease. Signs and symptoms include intestinal bleeding, anemia, and change in bowel habits. According to the degree of cellular differentiation, colonic adenocarcinomas are divided into well, moderately, and poorly differentiated. Histologic variants include mucinous adenocarcinoma, signet ring cell carcinoma, medullary carcinoma, serrated adenocarcinoma, cribriform comedo-type adenocarcinoma, and micropapillary adenocarcinoma.</data>
<data key="n_aliases">Adenocarcinoma - colon|Adenocarcinoma of Colon|Adenocarcinoma of the colon|Adenocarcinoma of the Colon|Colon Adenocarcinoma|Colonic Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C4349</data>
</node>
<node id="C5491">
<data key="n_label">Colon Adenosquamous Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1333082</data>
<data key="n_definition">An unusual colon carcinoma characterized by the presence of glandular and squamous carcinomatous components. The two carcinomatous components may be admixed within the tumor, or the two may appear separately in different areas.</data>
<data key="n_aliases">Adenosquamous Carcinoma of Colon|Adenosquamous Carcinoma of the Colon|Adenosquamous Colon Carcinoma|Colon Adenosquamous Cancer|Colon Adenosquamous Carcinoma|Colonic Adenosquamous Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C5491</data>
</node>
<node id="C90507">
<data key="n_label">Colon Cancer by AJCC v6 Stage</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Stage/Grade</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C2983706</data>
<data key="n_definition">A term that refers to the staging of colon carcinoma according to the American Joint Committee on Cancer, 6th edition.</data>
<data key="n_aliases">Colon Cancer by AJCC v6 Stage|Colon Carcinoma by AJCC v6 Stage</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C90507</data>
</node>
<node id="C91224">
<data key="n_label">Colon Cancer by AJCC v7 Stage</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Stage/Grade</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C2984088</data>
<data key="n_definition">A term that refers to the staging of colon carcinoma according to the American Joint Committee on Cancer, 7th edition.</data>
<data key="n_aliases">Colon Cancer by AJCC v7 Stage|Colon Carcinoma by AJCC v7 Stage</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C91224</data>
</node>
<node id="C134251">
<data key="n_label">Colon Cancer by AJCC v8 Stage</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Stage/Grade</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A term that refers to the staging of colon cancer according to the American Joint Committee on Cancer, 8th edition. This staging system applies to adenocarcinomas, high-grade neuroendocrine carcinomas, and squamous cell carcinomas of the colon. (from AJCC 8th Ed.)</data>
<data key="n_aliases">Colon Cancer by AJCC v8 Stage|Colon Carcinoma by AJCC v8 Stage</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C134251</data>
</node>
<node id="C226294">
<data key="n_label">Colon Carcinoma In Situ</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">An intraepithelial carcinoma arising from the colon without evidence of invasion.</data>
<data key="n_aliases">Carcinoma in situ of colon|Colon Carcinoma In Situ</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C226294</data>
</node>
<node id="C203384">
<data key="n_label">Colon Neuroendocrine Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">An aggressive high-grade carcinoma with neuroendocrine differentiation that arises from the colon. It is composed of malignant small or large cells. The mitotic count is more than 20 per 2 mm2 and/or the Ki-67 index is more than 20%.</data>
<data key="n_aliases">Colon NEC|Colon Neuroendocrine Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C203384</data>
</node>
<node id="C5490">
<data key="n_label">Colon Squamous Cell Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1333100</data>
<data key="n_definition">A very rare colon carcinoma characterized by the presence of a malignant squamous cell infiltrate.</data>
<data key="n_aliases">Colon Epidermoid Carcinoma|Colon Squamous Cell Cancer|Colon Squamous Cell Carcinoma|Colonic Epidermoid Carcinoma|Colonic Squamous Cell Carcinoma|Epidermoid Carcinoma of Colon|Epidermoid Carcinoma of the Colon|Squamous Cell Carcinoma of Colon|Squamous Cell Carcinoma of the Colon|Squamous Cell Colon Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C5490</data>
</node>
<node id="C7100">
<data key="n_label">Colon Undifferentiated Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C2355642</data>
<data key="n_definition">A usually aggressive carcinoma that arises from the colon and is composed of malignant cells which do not display evidence of glandular, squamous, or transitional cell differentiation.</data>
<data key="n_aliases">Carcinoma Simplex of the Colon.|Colon Anaplastic Carcinoma|Colon Undifferentiated Carcinoma|Undifferentiated Carcinoma of Colon|Undifferentiated Carcinoma of the Colon|Undifferentiated Colon Cancer|Undifferentiated Colonic Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C7100</data>
</node>
<node id="C172699">
<data key="n_label">Colorectal Adenoma-Like Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A well differentiated colorectal adenocarcinoma with good prognosis. It resembles a villous adenoma on the surface.</data>
<data key="n_aliases">Colorectal Adenoma-Like Adenocarcinoma|Colorectal Villous Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C172699</data>
</node>
<node id="C157366">
<data key="n_label">Colorectal Carcinoma Metastatic in the Liver</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Clinical Course</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A carcinoma that originates from the colorectal area and has spread to the liver.</data>
<data key="n_aliases">Colorectal Carcinoma Metastatic in the Liver</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C157366</data>
</node>
<node id="C153224">
<data key="n_label">Colorectal Carcinoma Metastatic in the Lung</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Clinical Course</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A carcinoma that originates from the wall of the colon or rectum and has spread to the lungs.</data>
<data key="n_aliases">Colorectal Carcinoma Metastatic in the Lung|Metastatic Colorectal Cancer in the Lung</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C153224</data>
</node>
<node id="C96488">
<data key="n_label">Colorectal Cribriform Comedo-Type Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C3272812</data>
<data key="n_definition">A rare, invasive colorectal adenocarcinoma characterized by the presence of malignant cribriform glands with central necrotic changes.</data>
<data key="n_aliases">Colorectal Cribriform Comedo-Type Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C96488</data>
</node>
<node id="C213111">
<data key="n_label">Colorectal Goblet Cell Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">An extremely rare colorectal adenocarcinoma that exhibits neuroendocrine differentiation and is associated with the presence of neoplastic signet-ring cells resembling goblet cells.</data>
<data key="n_aliases">Colorectal GCA|Colorectal Goblet Cell Adenocarcinoma|Colorectal Goblet Cell Carcinoid</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C213111</data>
</node>
<node id="C213479">
<data key="n_label">Colorectal Hepatoid Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A rare and aggressive extrahepatic carcinoma that morphologically and immunophenotypically resembles hepatocellular carcinoma and arises from the colon or rectum.</data>
<data key="n_aliases">Colorectal Hepatoid Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C213479</data>
</node>
<node id="C96157">
<data key="n_label">Colorectal Large Cell Neuroendocrine Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C3272608</data>
<data key="n_definition">An aggressive high-grade carcinoma with neuroendocrine differentiation that arises from the colon or rectum and is composed of malignant large cells. The mitotic count is more than 20 per 2 mm2 and/or the Ki-67 index is more than 20%.</data>
<data key="n_aliases">Colorectal Large Cell Neuroendocrine Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C96157</data>
</node>
<node id="C43590">
<data key="n_label">Colorectal Medullary Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Disease Concept</data>
<data key="n_research_axis">Disease taxonomy</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1707438</data>
<data key="n_definition">A colorectal adenocarcinoma characterized by the presence of sheets of malignant epithelial cells with vesicular nuclei, prominent nucleoli, and abundant eosinophilic cytoplasm. It usually has a favorable prognosis.</data>
<data key="n_aliases">Colorectal Medullary Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C43590</data>
</node>
<node id="C96491">
<data key="n_label">Colorectal Micropapillary Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C3272815</data>
<data key="n_definition">A rare, invasive colorectal adenocarcinoma characterized by the presence of clusters of malignant glandular cells within stromal spaces.</data>
<data key="n_aliases">Colorectal Micropapillary Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C96491</data>
</node>
<node id="C9447">
<data key="n_label">Colorectal Moderately Differentiated Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1333860</data>
<data key="n_definition">A colorectal adenocarcinoma characterized by the presence of a malignant cellular infiltrate with 50-95% glandular formation.</data>
<data key="n_aliases">Colorectal Moderately Differentiated Adenocarcinoma|Grade 2 Colorectal Adenocarcinoma|Grade II Colorectal Adenocarcinoma|Low Grade Colorectal Adenocarcinoma|Moderately Differentiated Colorectal Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C9447</data>
</node>
<node id="C43585">
<data key="n_label">Colorectal Mucinous Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1707439</data>
<data key="n_definition">An invasive colorectal adenocarcinoma characterized by the presence of extracellular mucin pools that contain malignant glandular epithelial structures. The extracellular mucin pools occupy more than 50% of the malignant lesion.</data>
<data key="n_aliases">Colorectal Mucinous Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C43585</data>
</node>
<node id="C172694">
<data key="n_label">Colorectal Poorly Cohesive Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">An adenocarcinoma that arises from the colorectal mucosa and is characterized by the presence of isolated malignant cells or malignant cells that form small aggregates.</data>
<data key="n_aliases">Colorectal Poorly Cohesive Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C172694</data>
</node>
<node id="C9448">
<data key="n_label">Colorectal Poorly Differentiated Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1333856</data>
<data key="n_definition">A colorectal adenocarcinoma characterized by the presence of a malignant cellular infiltrate with less than 50% glandular formation.</data>
<data key="n_aliases">Colorectal Poorly Differentiated Adenocarcinoma|Grade 3 Colorectal Adenocarcinoma|Grade III Colorectal Adenocarcinoma|High Grade Colorectal Adenocarcinoma|Poorly Differentiated Colorectal Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C9448</data>
</node>
<node id="C96485">
<data key="n_label">Colorectal Serrated Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C3472623</data>
<data key="n_definition">A rare, invasive colorectal adenocarcinoma characterized by the presence of a malignant infiltrate with serrated glandular architecture.</data>
<data key="n_aliases">Colorectal Serrated Adenocarcinoma|Serrated adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C96485</data>
</node>
<node id="C43587">
<data key="n_label">Colorectal Small Cell Neuroendocrine Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1707441</data>
<data key="n_definition">An aggressive high-grade carcinoma with neuroendocrine differentiation that arises from the colon or rectum and is composed of malignant small cells. The mitotic count is more than 20 per 2 mm2 and/or the Ki-67 index is more than 20%.</data>
<data key="n_aliases">Colorectal Small Cell Carcinoma|Colorectal Small Cell Neuroendocrine Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C43587</data>
</node>
<node id="C9446">
<data key="n_label">Colorectal Well Differentiated Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1333867</data>
<data key="n_definition">A colorectal adenocarcinoma characterized by the presence of a malignant cellular infiltrate with more than 95% glandular formation.</data>
<data key="n_aliases">Colorectal Well Differentiated Adenocarcinoma|Grade 1 Colorectal Adenocarcinoma|Grade I Colorectal Adenocarcinoma|Low Grade Colorectal Adenocarcinoma|Well Differentiated Colorectal Adenocarcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C9446</data>
</node>
<node id="C202634">
<data key="n_label">Distal Colon Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Disease Concept</data>
<data key="n_research_axis">Disease taxonomy</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A colon carcinoma that arises from the splenic flexure, descending colon, or sigmoid colon.</data>
<data key="n_aliases">Distal Colon Cancer|Distal Colon Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C202634</data>
</node>
<node id="C214793">
<data key="n_label">Early Stage Colon Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Stage/Grade</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A stage term referring to colon carcinoma that is limited to the colon or local lymph nodes, without metastasis to distant anatomic sites.</data>
<data key="n_aliases">Early Stage Colon Cancer|Early Stage Colon Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C214793</data>
</node>
<node id="C164228">
<data key="n_label">Hereditary Colon Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Disease Concept</data>
<data key="n_research_axis">Disease taxonomy</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">Colon carcinoma that has developed in relatives of patients with a history of colon carcinoma.</data>
<data key="n_aliases">Hereditary Colon Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C164228</data>
