<node id="C211028">
<data key="n_label">Metastatic Unresectable Colorectal Carcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Clinical Course</data>
<data key="n_research_axis">Clinical stage/course</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">A colorectal carcinoma that has spread from its original site of growth to another anatomic site and is not amenable to surgical resection.</data>
<data key="n_aliases">Metastatic Unresectable Colorectal Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C211028</data>
</node>
