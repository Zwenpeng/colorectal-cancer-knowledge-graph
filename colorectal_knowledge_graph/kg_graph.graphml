<node id="C7476">
<data key="n_label">Anal Margin Paget Disease</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Associated Disease/Neoplasm</data>
<data key="n_research_axis">Associated conditions</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C1332270</data>
<data key="n_definition">Paget disease involving the perianal skin.</data>
<data key="n_aliases">Anal Margin Paget Disease|Anal Margin Paget's Disease|Paget Disease of the Anal Margin|Paget's Disease of the Anal Margin|Perianal Skin Paget's Disease</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C7476</data>
