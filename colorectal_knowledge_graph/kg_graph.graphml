<data key="n_semantic_types">Gene or Genome</data>
<data key="n_umls_cui">C1332126</data>
<data key="n_definition">This gene is involved in signal transduction and plays a role in development.</data>
<data key="n_aliases">Axin 2 Gene|AXIN2|AXIN2 Gene</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C20763</data>
