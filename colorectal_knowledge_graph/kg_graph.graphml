<node id="C34128">
<data key="n_label">Cloacal Membrane</data>
<data key="n_node_kind">Entity</data>
<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Other Entity</data>
<data key="n_research_axis">Other</data>
<data key="n_semantic_types">Embryonic Structure</data>
<data key="n_umls_cui">C0231056</data>
<data key="n_definition">The membrane covering the embryonic cloaca; it is composed from ectoderm and endoderm, and, following cloacal folding during embryonic development, the membrane ruptures and is absorbed, becoming continuous with the rectum.</data>
<data key="n_aliases">Cloacal Membrane</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C34128</data>
