<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Associated Disease/Neoplasm</data>
<data key="n_research_axis">Associated conditions</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C0850572</data>
<data key="n_definition">An adenoma that arises from the colon. The group of colon adenomas includes conventional adenomas and traditional serrated adenomas.</data>
<data key="n_aliases">Adenoma of Colon|Adenoma of the Colon|Colon Adenoma|Colonic Adenoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C3864</data>
