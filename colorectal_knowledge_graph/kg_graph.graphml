<data key="n_in_colorectal_tree">N</data>
<data key="n_category">Gene/Genome</data>
<data key="n_research_axis">Molecular genetics</data>
<data key="n_semantic_types">Gene or Genome</data>
<data key="n_umls_cui">C1708809</data>
<data key="n_definition">Human MCC wild-type allele is located in the vicinity of 5q21-q22 and is approximately 360 kb in length. This allele, which encodes colorectal mutant cancer protein, may play a role in tumor suppression. MCC wild-type allele is a candidate colorectal tumor suppressor gene.</data>
<data key="n_aliases">FLJ46755|MCC wt Allele|MCC1|Mutated in Colorectal Cancers wt Allele</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C54309</data>
