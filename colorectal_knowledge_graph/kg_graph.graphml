<node id="C96496">
<data key="n_label">Ulcerative Colitis-Associated Colorectal Adenocarcinoma</data>
<data key="n_node_kind">Concept</data>
<data key="n_in_colorectal_tree">Y</data>
<data key="n_category">Histology</data>
<data key="n_research_axis">Pathology/cytology</data>
<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui">C3272820</data>
<data key="n_definition">A colorectal adenocarcinoma that develops in patients with a history of ulcerative colitis. Such carcinomas are usually multiple and flat. Histologically, they are usually mucinous or signet-ring cell type.</data>
<data key="n_aliases">UC-Associated CRC|Ulcerative Colitis-Associated Colorectal Adenocarcinoma|Ulcerative Colitis-Associated Colorectal Carcinoma</data>
