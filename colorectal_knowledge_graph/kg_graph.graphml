<data key="n_semantic_types">Neoplastic Process</data>
<data key="n_umls_cui"></data>
<data key="n_definition">Colon carcinoma that is confined to the site in which it initially manifested without evidence of spread to other anatomic sites.</data>
<data key="n_aliases">Localized Colon Carcinoma</data>
<data key="n_nci_url">https://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI_Thesaurus&amp;ns=ncit&amp;code=C220569</data>
