<data key="n_category">Treatment Regimen</data>
<data key="n_research_axis">Therapy</data>
<data key="n_semantic_types">Therapeutic or Preventive Procedure</data>
<data key="n_umls_cui">C1879915</data>
<data key="n_definition">A regimen consisting of capecitabine and oxaliplatin that can be used for the treatment of ampullary, appendiceal, pancreatic and small bowel adenocarcinomas, anal, colorectal, gastric, esophageal and esophagogastric junction cancers, certain neuroendocrine tumors, occult primary tumors and mucinous carcinoma of the ovary. Low-dose CapeOX may be used for the treatment of gastric, esophageal and esophagogastric junction cancers.</data>
<data key="n_aliases">Capecitabine-Oxaliplatin|Capecitabine-Oxaliplatin Regimen|Capecitabine/Oxaliplatin|Capecitabine/Oxaliplatin Regimen|CapeOx|CAPEOX Regimen|CapeOx Regimen|CAPOX|CAPOX Regimen</data>
